{
  "description": "Stop Socratic requests before Claude Code processes them when no trusted Host capability is available.",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/claude_preflight.py\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
