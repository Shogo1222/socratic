{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Socratic Narrow Runner Experiment Plan",
  "type": "object",
  "required": ["version", "source", "profile", "round", "mutations"],
  "properties": {
    "version": { "const": 1 },
    "source": {
      "type": "object",
      "required": ["sha256"],
      "properties": {
        "sha256": {
          "oneOf": [
            { "const": "runner-computed" },
            { "type": "string", "pattern": "^[a-f0-9]{64}$" }
          ]
        }
      },
      "additionalProperties": false
    },
    "profile": {
      "type": "object",
      "required": ["name", "dependency_policy", "selection"],
      "properties": {
        "name": { "const": "python-unittest" },
        "dependency_policy": {
          "type": "object",
          "required": ["mode"],
          "properties": {
            "mode": { "const": "use-existing" }
          },
          "additionalProperties": false
        },
        "selection": {
          "type": "object",
          "required": ["modules", "classes", "methods"],
          "properties": {
            "modules": {
              "type": "array",
              "items": {
                "type": "string",
                "pattern": "^[A-Za-z_][A-Za-z0-9_]*(?:\\.[A-Za-z_][A-Za-z0-9_]*)*$"
              },
              "minItems": 1,
              "uniqueItems": true
            },
            "classes": {
              "type": "array",
              "items": { "type": "string", "pattern": "^[A-Za-z_][A-Za-z0-9_]*$" },
              "uniqueItems": true
            },
            "methods": {
              "type": "array",
              "items": { "type": "string", "pattern": "^test_[A-Za-z0-9_]+$" },
              "uniqueItems": true
            }
          },
          "additionalProperties": false
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "selection": {
                "properties": { "methods": { "minItems": 1 } },
                "required": ["methods"]
              }
            },
            "required": ["selection"]
          },
          "then": {
            "properties": {
              "selection": {
                "properties": { "classes": { "minItems": 1 } }
              }
            }
          }
        }
      ],
      "additionalProperties": false
    },
    "round": {
      "type": "object",
      "required": ["baseline", "timeout_seconds"],
      "properties": {
        "baseline": { "const": "full" },
        "timeout_seconds": { "type": "integer", "minimum": 1, "maximum": 3600 }
      },
      "additionalProperties": false
    },
    "mutations": {
      "type": "array",
      "minItems": 1,
      "maxItems": 16,
      "items": {
        "type": "object",
        "required": [
          "id", "contract_ids", "accident", "oracle", "targets"
        ],
        "properties": {
          "id": { "type": "string", "pattern": "^MUT-[0-9]{3,}$" },
          "contract_ids": {
            "type": "array",
            "items": { "type": "string", "pattern": "^(DEC|INV|FX)-[0-9]{3,}$" },
            "minItems": 1,
            "uniqueItems": true
          },
          "accident": { "type": "string", "minLength": 1, "maxLength": 1000 },
          "oracle": { "type": "string", "minLength": 1, "maxLength": 1000 },
          "targets": {
            "type": "array",
            "minItems": 1,
            "maxItems": 4,
            "items": {
              "type": "object",
              "required": ["path", "preimage_sha256", "operations"],
              "properties": {
                "path": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 500,
                  "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\).+$"
                },
                "preimage_sha256": {
                  "oneOf": [
                    { "const": "runner-computed" },
                    { "type": "string", "pattern": "^[a-f0-9]{64}$" }
                  ]
                },
                "operations": {
                  "type": "array",
                  "minItems": 1,
                  "maxItems": 8,
                  "items": {
                    "oneOf": [
                      {
                        "type": "object",
                        "required": ["type", "before", "after"],
                        "properties": {
                          "type": { "const": "replace-exact" },
                          "before": { "type": "string", "minLength": 1, "maxLength": 16384 },
                          "after": { "type": "string", "maxLength": 16384 }
                        },
                        "additionalProperties": false
                      },
                      {
                        "type": "object",
                        "required": ["type", "before"],
                        "properties": {
                          "type": { "const": "delete-exact" },
                          "before": { "type": "string", "minLength": 1, "maxLength": 16384 }
                        },
                        "additionalProperties": false
                      }
                    ]
                  }
                }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
