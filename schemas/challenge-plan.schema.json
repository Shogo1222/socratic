{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Socratic Anchored Challenge Batch Plan",
  "type": "object",
  "required": ["version", "command_id", "max_parallel", "challenges"],
  "properties": {
    "version": { "const": 2 },
    "command_id": { "type": "string", "pattern": "^CMD-[0-9]{3,}$" },
    "max_parallel": { "type": "integer", "minimum": 1, "maximum": 8 },
    "challenges": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "items": {
        "type": "object",
        "required": [
          "id", "contract_ids", "accident", "expected_detection", "severity",
          "likelihood", "code_location", "mutation"
        ],
        "properties": {
          "id": { "type": "string", "pattern": "^MUT-[0-9]{3,}$" },
          "contract_ids": {
            "type": "array",
            "items": { "type": "string", "pattern": "^(DEC|INV|FX)-[0-9]{3,}$" },
            "minItems": 1,
            "uniqueItems": true
          },
          "accident": { "type": "string", "minLength": 1, "maxLength": 1000 },
          "expected_detection": { "type": "string", "minLength": 1, "maxLength": 1000 },
          "severity": { "enum": ["low", "medium", "high", "critical"] },
          "likelihood": { "enum": ["low", "medium", "high"] },
          "code_location": { "type": "string", "minLength": 1, "maxLength": 1000 },
          "mutation": {
            "oneOf": [
              {
                "type": "object",
                "required": ["kind", "relative_path", "before", "after"],
                "properties": {
                  "kind": { "const": "replace-exact" },
                  "relative_path": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 500,
                    "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\).+$"
                  },
                  "before": { "type": "string", "minLength": 1, "maxLength": 8192 },
                  "after": { "type": "string", "maxLength": 8192 }
                },
                "additionalProperties": false
              },
              {
                "type": "object",
                "required": ["kind", "relative_path", "before"],
                "properties": {
                  "kind": { "const": "delete-exact" },
                  "relative_path": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 500,
                    "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\).+$"
                  },
                  "before": { "type": "string", "minLength": 1, "maxLength": 8192 }
                },
                "additionalProperties": false
              }
            ]
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
