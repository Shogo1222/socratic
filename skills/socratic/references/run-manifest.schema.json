{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Socratic Run Manifest",
  "type": "object",
  "required": [
    "version",
    "run_id",
    "status",
    "write_mode",
    "socratic_version",
    "entrypoint",
    "skill_root",
    "primary_root",
    "sandbox_root",
    "prepared_root",
    "host",
    "protection",
    "environment",
    "ledger_path",
    "artifact_root",
    "artifact_index_path",
    "primary_sha256",
    "change_context"
  ],
  "properties": {
    "version": {
      "const": 1
    },
    "run_id": {
      "type": "string",
      "pattern": "^[a-f0-9]{32}$"
    },
    "started_at_epoch": {
      "type": "number",
      "minimum": 0,
      "description": "Wall-clock epoch seconds when preflight created this run"
    },
    "status": {
      "const": "ready"
    },
    "write_mode": {
      "const": "review-only"
    },
    "socratic_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$"
    },
    "entrypoint": {
      "const": "socratic/scripts/run_review.py"
    },
    "skill_root": {
      "type": "string",
      "minLength": 1
    },
    "primary_root": {
      "type": "string",
      "minLength": 1
    },
    "sandbox_root": {
      "type": [
        "string",
        "null"
      ]
    },
    "prepared_root": {
      "type": "string",
      "minLength": 1
    },
    "host": {
      "type": "object",
      "required": [
        "adapter_id",
        "run_nonce",
        "storage_root"
      ],
      "properties": {
        "adapter_id": {
          "type": "string",
          "minLength": 1
        },
        "run_nonce": {
          "type": "string",
          "minLength": 32
        },
        "storage_root": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "protection": {
      "type": "object",
      "required": [
        "mode",
        "verified",
        "primary_root",
        "details"
      ],
      "properties": {
        "mode": {
          "enum": [
            "os-read-only",
            "permission-read-only",
            "host-events",
            "os-audit",
            "unavailable"
          ]
        },
        "verified": {
          "type": "boolean",
          "description": "Schema v7 compatibility field: true means the Runner accepted a trusted Host attestation; it does not assert independent OS verification by the Runner."
        },
        "primary_root": {
          "type": "string",
          "minLength": 1
        },
        "details": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "environment": {
      "type": "object",
      "required": [
        "HOME",
        "TMPDIR",
        "XDG_CACHE_HOME",
        "npm_config_cache"
      ],
      "properties": {
        "HOME": {
          "type": "string",
          "minLength": 1
        },
        "TMPDIR": {
          "type": "string",
          "minLength": 1
        },
        "XDG_CACHE_HOME": {
          "type": "string",
          "minLength": 1
        },
        "npm_config_cache": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "ledger_path": {
      "type": "string",
      "minLength": 1
    },
    "artifact_root": {
      "type": "string",
      "minLength": 1
    },
    "artifact_index_path": {
      "type": "string",
      "minLength": 1
    },
    "primary_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "change_context": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "source",
            "head_root"
          ],
          "properties": {
            "source": {
              "const": "local-workspace"
            },
            "head_root": {
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "source",
            "number",
            "url",
            "base_ref",
            "base_sha",
            "head_ref",
            "head_sha",
            "base_root",
            "head_root"
          ],
          "properties": {
            "source": {
              "const": "github-pull-request"
            },
            "number": {
              "type": "integer",
              "minimum": 1
            },
            "url": {
              "type": "string",
              "pattern": "^https:\\/\\/github\\.com/"
            },
            "base_ref": {
              "type": "string",
              "minLength": 1
            },
            "base_sha": {
              "type": "string",
              "pattern": "^[a-f0-9]{40}$"
            },
            "head_ref": {
              "type": "string",
              "minLength": 1
            },
            "head_sha": {
              "type": "string",
              "pattern": "^[a-f0-9]{40}$"
            },
            "base_root": {
              "type": "string",
              "minLength": 1
            },
            "head_root": {
              "type": "string",
              "minLength": 1
            },
            "changed_files": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "uniqueItems": true
            }
          },
          "additionalProperties": false
        }
      ]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "ready"
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "properties": {
          "sandbox_root": {
            "type": "string",
            "minLength": 1
          },
          "protection": {
            "properties": {
              "verified": {
                "const": true
              }
            }
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
