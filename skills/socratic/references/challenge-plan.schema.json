{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Socratic Challenge Batch Plan",
  "type": "object",
  "required": ["version", "max_parallel", "challenges"],
  "properties": {
    "version": { "const": 1 },
    "max_parallel": { "type": "integer", "minimum": 1, "maximum": 8 },
    "challenges": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "items": {
        "type": "object",
        "required": ["id", "contract_ids", "mutation", "command", "timeout_seconds"],
        "properties": {
          "id": { "type": "string", "pattern": "^MUT-[0-9]{3,}$" },
          "contract_ids": {
            "type": "array",
            "items": { "type": "string", "pattern": "^(DEC|INV|FX)-[0-9]{3,}$" },
            "minItems": 1,
            "uniqueItems": true
          },
          "mutation": {
            "oneOf": [
              {
                "type": "object",
                "required": ["kind", "relative_target", "content_utf8"],
                "properties": {
                  "kind": { "const": "write" },
                  "relative_target": { "type": "string", "minLength": 1 },
                  "content_utf8": { "type": "string" }
                },
                "additionalProperties": false
              },
              {
                "type": "object",
                "required": ["kind", "relative_path"],
                "properties": {
                  "kind": { "const": "prebuilt" },
                  "relative_path": { "type": "string", "minLength": 1 }
                },
                "additionalProperties": false
              }
            ]
          },
          "command": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "timeout_seconds": { "type": "integer", "minimum": 1, "maximum": 3600 }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
