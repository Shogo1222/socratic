{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Canonical Socratic Review",
  "type": "object",
  "required": ["review_this", "we_verified", "still_at_risk", "copy_ready_comments"],
  "properties": {
    "review_this": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["kind", "body", "contract_ids"],
        "properties": {
          "kind": {
            "enum": ["confirmed-behavior", "behavior-difference", "test-gap", "needs-decision"]
          },
          "body": { "type": "string", "minLength": 1 },
          "contract_ids": {
            "type": "array",
            "items": { "type": "string", "pattern": "^(DEC|INV|FX|UNR)-[0-9]{3,}$" },
            "minItems": 1,
            "uniqueItems": true
          }
        },
        "additionalProperties": false
      }
    },
    "we_verified": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "still_at_risk": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "copy_ready_comments": {
      "type": "array",
      "maxItems": 3,
      "items": {
        "type": "object",
        "required": ["tag", "file", "line", "body", "evidence"],
        "properties": {
          "tag": { "enum": ["Intent decision", "Behavior difference", "Test gap"] },
          "file": { "type": "string", "minLength": 1 },
          "line": { "type": "integer", "minimum": 1 },
          "body": { "type": "string", "minLength": 1 },
          "evidence": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
